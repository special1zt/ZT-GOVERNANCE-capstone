# --- KEYCLOAK SETTINGS ---
# Use these to log into the Keycloak Admin Console at http://localhost:8080
KC_ADMIN_USER=REPLACE_ME_KEYCLOAK_ADMIN_USER
KC_ADMIN_PASS=REPLACE_ME_KEYCLOAK_ADMIN_PASSWORD

# These tell the Python app how to talk to Keycloak inside Docker
KEYCLOAK_ISSUER=http://keycloak:8080/realms/capstone
KEYCLOAK_VALID_ISSUERS=http://keycloak:8080/realms/capstone,http://localhost:8080/realms/capstone
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/capstone/protocol/openid-connect/certs

# --- DATABASE SETTINGS ---
SECURITY_DB_ROOT_PASS=REPLACE_ME_SECURITY_DB_ROOT_PASSWORD
SECURITY_DB_USER=REPLACE_ME_SECURITY_DB_USER
SECURITY_DB_PASS=REPLACE_ME_SECURITY_DB_PASSWORD
SECURITY_DB_HOST=127.0.0.1
SECURITY_DB_PORT=3307

# --- ITSM Governance (GLPI) ---
GLPI_PORT=8030
GLPI_DB_ROOT_PASSWORD=REPLACE_ME_GLPI_DB_ROOT_PASSWORD
GLPI_DB_NAME=glpi
GLPI_DB_USER=REPLACE_ME_GLPI_DB_USER
GLPI_DB_PASSWORD=REPLACE_ME_GLPI_DB_PASSWORD
GLPI_USER_TOKEN=REPLACE_ME_GLPI_USER_TOKEN
GLPI_APP_TOKEN=REPLACE_ME_GLPI_APP_TOKEN

# --- Splunk ---
SPLUNK_PASSWORD=REPLACE_ME_SPLUNK_ADMIN_PASSWORD

# --- SCRIPT AGENT CREDS ---
AGENT_PASSWORD=REPLACE_ME_AGENT_PASSWORD

# Agent 1 - healthy representative
##AGENT_USER=agent1
##AGENT_PASSWORD=REPLACE_ME_AGENT_PASSWORD
##AGENT_DEVICE_ID=agent-dev-01

# Agent 2 - monitored representative
##AGENT2_USER=agent2
##AGENT2_PASSWORD=REPLACE_ME_AGENT2_PASSWORD
##AGENT_DEVICE_ID_02=agent-dev-02

# Infrastructure Config
RESOURCE_API_PORT=8000
KEYCLOAK_PORT=8080
